# Smart Wheel Engine Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# Broker Configuration
# =============================================================================

# Broker API credentials (choose one)
# IBKR_API_KEY=your-ibkr-api-key
# IBKR_SECRET=your-ibkr-secret
# IBKR_ACCOUNT_ID=your-account-id

# TD Ameritrade / Schwab
# TDA_API_KEY=your-tda-api-key
# TDA_REFRESH_TOKEN=your-refresh-token

# Alpaca
# ALPACA_API_KEY=your-alpaca-key
# ALPACA_SECRET_KEY=your-alpaca-secret
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# =============================================================================
# Data Providers
# =============================================================================

# Market data
# POLYGON_API_KEY=your-polygon-key
# ALPHA_VANTAGE_API_KEY=your-av-key

# Options data
# TRADIER_API_KEY=your-tradier-key
# CBOE_API_KEY=your-cboe-key

# =============================================================================
# Application Settings
# =============================================================================

# Environment
ENVIRONMENT=development
DEBUG=false

# Risk settings
MAX_POSITION_SIZE=0.20
MAX_PORTFOLIO_DELTA=0.50
MAX_DAILY_LOSS=0.03

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_FILE=logs/audit.log

# =============================================================================
# Database (optional)
# =============================================================================

# DATABASE_URL=postgresql://user:pass@localhost:5432/smartwheel
# REDIS_URL=redis://localhost:6379

# =============================================================================
# Notifications (optional)
# =============================================================================

# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
