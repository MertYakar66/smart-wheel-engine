# Smart Wheel Engine — environment template
# Copy to .env and fill in what you need. NEVER commit .env.
# Every variable below is actually read by tracked code (the reader is
# named per block). The engine has no broker/OMS surface (CLAUDE.md §3);
# there are no broker credentials here by design. Theta Terminal needs
# no env var — the connector targets the fixed local endpoint
# 127.0.0.1:25503 (engine/theta_connector.py).

# =============================================================================
# Core engine (SWE_*)
# =============================================================================

# Data provider: bloomberg (committed CSVs, default) | theta (live Terminal).
# Read by WheelRunner.connector; the SessionStart hook warns when unset.
SWE_DATA_PROVIDER=bloomberg

# HTTP API binding (engine_api.py). Per-terminal ports for parallel
# sessions come from scripts/setup-terminal.{sh,ps1} — see DECISIONS.md D15.
# SWE_API_PORT=8787
# SWE_API_HOST=127.0.0.1
# SWE_API_CORS_ORIGIN=http://localhost:3000

# Opt-in: put the live TradingView MCP chart provider first in the
# dossier chart chain (DECISIONS.md D13). Truthy: 1/true/yes/on.
# SWE_USE_MCP_CHART=0

# Opt-in: assemble the deep-history Bloomberg read (engine/data_connector.py).
# SWE_DEEP_HISTORY=0

# Directory overrides (parallel sessions / sandboxes; defaults are in-repo).
# SWE_DATA_PROCESSED_DIR=data_processed
# SWE_MODELS_DIR=models
# SWE_IBKR_DATA_DIR=data_processed/ibkr   # D24 read-only IBKR snapshot dir

# SEC EDGAR requires a User-Agent identifying you (engine/external_data/edgar_adapter.py).
# SWE_EDGAR_UA="your-name your-email@example.com"

# Sandbox bootstrap only: allow the SessionStart hook to pip-install
# globally when no venv is active (.claude/hooks/session_start.sh).
# SWE_ALLOW_GLOBAL_PIP=1

# =============================================================================
# Wheel policy knobs (config/settings.py, ml/wheel_model.py)
# =============================================================================

# WHEEL_ENV=development
# WHEEL_DATA_DIR=data
# WHEEL_INITIAL_CAPITAL=100000
# WHEEL_TARGET_DELTA=0.30
# WHEEL_MAX_POSITIONS=5
# WHEEL_MAX_DRAWDOWN=0.20

# =============================================================================
# TradingView webhook authentication (engine_api.py POST /api/tv/webhook)
# =============================================================================

# Preferred: HMAC-SHA256 signature check on the alert payload.
# TV_WEBHOOK_HMAC_SECRET=your-hmac-secret
# Legacy fallback: shared-secret field match.
# TV_WEBHOOK_SECRET=your-shared-secret

# =============================================================================
# Optional data / AI integrations
# =============================================================================

# FRED macro series (engine/external_data/fred_adapter.py).
# FRED_API_KEY=your-fred-key

# News sentiment pullers (scripts/pull_news_sentiment.py via pull_all.py
# step 7 — skipped when none is set). Operator-transparency only; no news
# feeds the EV authority (DECISIONS.md D18).
# POLYGON_API_KEY=your-polygon-key     # free tier covers /v2/reference/news
# FINNHUB_API_KEY=your-finnhub-key     # free tier covers /company-news
# BENZINGA_API_KEY=your-benzinga-key   # paid; native sentiment scores

# Local Ollama for trade memos (engine/trade_memo.py).
# OLLAMA_URL=http://localhost:11434
# OLLAMA_HEAVY_MODEL=qwen2.5:72b
# OLLAMA_FAST_MODEL=qwen2.5:32b

# =============================================================================
# Debug toggles
# =============================================================================

# Re-validate every Greek against finite differences (slow; engine/option_pricer.py).
# VALIDATE_GREEKS=0
