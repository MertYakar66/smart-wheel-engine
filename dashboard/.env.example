# ─── Optional API Keys ──────────────────────────────────────────────
# Finnhub: Free tier gives 60 calls/min for basic quotes
# Get one at: https://finnhub.io/register
FINNHUB_API_KEY=

# FRED: Federal Reserve Economic Data - free API key
# Get one at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ─── Ollama Configuration ──────────────────────────────────────────
# URL where Ollama is running (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Model to use for entity extraction and chat (default: qwen2.5:7b)
OLLAMA_MODEL=qwen2.5:7b

# ─── Engine Ollama Models (set in terminal, not here) ──────────────
# These are read by engine_api.py (Python), not the Next.js app.
# Set them in your terminal before running: python engine_api.py
#
#   $env:OLLAMA_HEAVY_MODEL = "qwen2.5:72b"   # PowerShell
#   export OLLAMA_HEAVY_MODEL=qwen2.5:72b      # bash/zsh
#
# OLLAMA_HEAVY_MODEL=qwen2.5:72b   # Used for full AI trade memos
# OLLAMA_FAST_MODEL=qwen2.5:32b    # Used for quick summaries

# ─── Valyu Unified Search API (Optional) ───────────────────────────
# One retrieval interface across web, news, financial data, filings, and research
# Get one at: https://valyu.network/
VALYU_API_KEY=
VALYU_API_URL=https://api.valyu.network/v1

# ─── Daytona Code Execution (Optional) ─────────────────────────────
# Secure Python sandbox for analytics (event studies, factor models, etc.)
# Get one at: https://daytona.io/
DAYTONA_API_KEY=
DAYTONA_API_URL=https://api.daytona.io/v1
